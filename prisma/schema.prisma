generator client {
  provider = "prisma-client-js"  
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Student {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  matricula String
  grado     String
  cursos    String[]

  @@map("students")
}

model Course {
  id          String @id @map("_id")
  name        String
  description String
  credits     Int

  @@map("courses")
}